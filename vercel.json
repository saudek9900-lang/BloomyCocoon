{
  "rewrites": [
    {
      "source": "/collections",
      "destination": "/collections/index.html"
    },
    {
      "source": "/custom-order",
      "destination": "/custom-order/index.html"
    },
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/faq",
      "destination": "/faq/index.html"
    },
    {
      "source": "/contact",
      "destination": "/contact/index.html"
    },
    {
      "source": "/((?!assets/|images/|favicon.ico|favicon.svg|apple-touch-icon.png|site.webmanifest|robots.txt|sitemap.xml).*)",
      "destination": "/index.html"
    }
  ]
}
